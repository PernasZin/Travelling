<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TRAVELING — Explore o Mundo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@200;300;400;500;600&display=swap" rel="stylesheet">
<script src="https://d3js.org/d3.v7.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js"></script>
<style>
/* ═══ TOKENS ═══════════════════════════════════════════════════════════════ */
:root {
  --gold:#c8a850; --gold2:#dfc070; --gold3:#7a6030; --gold4:rgba(200,168,80,.12);
  --eu:#b8924a; --eu-g:rgba(184,146,74,.22);
  --na:#3a9cb0; --na-g:rgba(58,156,176,.22);
  --sa:#32a870; --sa-g:rgba(50,168,112,.22);
  --af:#c87840; --af-g:rgba(200,120,64,.22);
  --as:#a04040; --as-g:rgba(160,64,64,.22);
  --oc:#5a7cc8; --oc-g:rgba(90,124,200,.22);
  --ease:cubic-bezier(.16,1,.3,1);
}
[data-theme="dark"] {
  --bg:#161616; --bg2:#1e1e1e; --bg3:#252525; --bg4:#2e2e2e;
  --fg:rgba(240,233,218,.96); --muted:rgba(240,233,218,.42); --dim:rgba(240,233,218,.68);
  --glass:rgba(22,22,22,.90); --gb:rgba(200,168,80,.14);
  --land:#2a2a2a; --border:#3a3a3a;
  --tbar:rgba(18,18,18,.96); --card:rgba(255,255,255,.05);
  --inp-bg:rgba(30,30,30,.92); --inp-b:rgba(200,168,80,.18);
  --scr:rgba(120,95,45,.45); --shadow:rgba(0,0,0,.45);
}
[data-theme="light"] {
  --bg:#fdfaf3; --bg2:#f5f0e6; --bg3:#ede8da; --bg4:#e4ddd0;
  --fg:rgba(28,20,8,.88); --muted:rgba(28,20,8,.36); --dim:rgba(28,20,8,.58);
  --glass:rgba(253,250,243,.94); --gb:rgba(160,120,40,.16);
  --land:#d4ccb4; --border:#bfb898;
  --tbar:rgba(253,250,243,.97); --card:rgba(0,0,0,.028);
  --inp-bg:rgba(248,244,234,.95); --inp-b:rgba(160,120,40,.22);
  --scr:rgba(160,120,40,.25); --shadow:rgba(60,40,0,.12);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);color:var(--fg);}
body{font-family:'Montserrat',sans-serif;font-weight:300;transition:background .35s,color .35s;}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit;}
::-webkit-scrollbar{width:2px;}
::-webkit-scrollbar-thumb{background:var(--scr);border-radius:2px;}
:focus-visible{outline:2px solid var(--gold);outline-offset:2px;}

/* ═══ LOADING ═══════════════════════════════════════════════════════════════ */
#loading{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity .9s ease;}
#loading.hide{opacity:0;pointer-events:none;}
.ld-mark{font-family:'Playfair Display',serif;font-size:1.8rem;letter-spacing:.65em;color:var(--fg);margin-bottom:4px;animation:fIn .7s ease both;}
.ld-sub{font-size:.41rem;letter-spacing:.45em;color:var(--muted);text-transform:uppercase;margin-bottom:28px;animation:fIn .7s ease .18s both;}
.ld-bar{width:160px;height:1px;background:rgba(200,168,80,.15);overflow:hidden;position:relative;}
.ld-bar::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,var(--gold),transparent);animation:ldSl 1.2s ease infinite;}
@keyframes ldSl{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
@keyframes fIn{from{opacity:0}to{opacity:1}}
@keyframes fDn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}

/* ═══ TOPBAR ════════════════════════════════════════════════════════════════ */
#topbar{
  position:fixed;top:0;left:0;right:0;height:52px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 18px 0 16px;
  background:var(--tbar);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
  border-bottom:1px solid var(--gb);z-index:400;
}
#logo{
  font-family:'Playfair Display',serif;font-size:1.05rem;letter-spacing:.52em;
  font-weight:400;cursor:pointer;user-select:none;
  opacity:0;animation:fDn .8s ease .4s forwards;
  transition:opacity .2s;padding:6px 4px;
}
#logo:hover{opacity:.8!important;}
#logo em{color:var(--gold);font-style:normal;}
#topbar-right{display:flex;align-items:center;gap:9px;opacity:0;animation:fIn .7s ease .95s forwards;}
.tb-btn{
  display:flex;align-items:center;gap:5px;
  border:1px solid var(--gb);color:var(--muted);font-size:.42rem;
  letter-spacing:.19em;text-transform:uppercase;padding:5px 11px;
  transition:all .22s;white-space:nowrap;border-radius:3px;
}
.tb-btn:hover{border-color:var(--gold);color:var(--gold2);}
.tb-btn.hidden{display:none!important;}
#counter-badge{
  display:flex;align-items:center;gap:6px;
  padding:5px 11px;background:var(--gold4);
  border:1px solid rgba(200,168,80,.18);border-radius:3px;
  font-size:.42rem;letter-spacing:.13em;color:var(--gold);white-space:nowrap;
}
.ctr-n{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--gold2);font-weight:400;line-height:1;}
#theme-btn{
  width:30px;height:30px;border:1px solid var(--gb);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:.85rem;transition:all .22s;
}
#theme-btn:hover{border-color:var(--gold);background:var(--gold4);}

/* ═══ SEARCH ════════════════════════════════════════════════════════════════ */
#sw{position:relative;}
#si{
  background:var(--inp-bg);border:1px solid var(--inp-b);outline:none;
  color:var(--fg);font-family:'Montserrat',sans-serif;font-size:.5rem;
  font-weight:300;letter-spacing:.13em;padding:6px 28px 6px 10px;
  width:110px;transition:width .4s var(--ease),border-color .25s;
  text-transform:uppercase;caret-color:var(--gold);border-radius:3px;
}
#si::placeholder{color:var(--muted);}
#si:focus{width:180px;border-color:rgba(200,168,80,.42);}
.si-ico{position:absolute;right:8px;top:50%;transform:translateY(-50%);color:var(--gold3);font-size:.65rem;pointer-events:none;}
#sug{
  position:absolute;top:calc(100% + 4px);left:0;right:0;
  background:var(--glass);backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);
  border:1px solid var(--gb);max-height:220px;overflow-y:auto;display:none;z-index:500;border-radius:3px;
}
#sug.open{display:block;}
.sg-row{
  padding:8px 11px;font-size:.51rem;letter-spacing:.09em;color:var(--dim);
  cursor:pointer;text-transform:uppercase;display:flex;align-items:center;gap:8px;
  transition:background .1s,color .1s;
}
.sg-row:hover,.sg-row:focus{background:var(--gold4);color:var(--gold2);}
.sg-fl{font-size:.88rem;flex-shrink:0;line-height:1;}
.sg-ct{font-size:.37rem;color:var(--gold3);margin-left:auto;letter-spacing:.09em;}

/* ═══ BREADCRUMB ════════════════════════════════════════════════════════════ */
#bc{position:fixed;top:59px;left:42px;z-index:200;display:flex;align-items:center;gap:6px;opacity:0;transition:opacity .3s;pointer-events:none;}
#bc.vis{opacity:1;pointer-events:all;}
.bc-i{font-size:.4rem;letter-spacing:.16em;color:var(--muted);text-transform:uppercase;cursor:pointer;transition:color .2s;background:none;border:none;}
.bc-i:hover{color:var(--gold);}
.bc-cur{color:var(--gold2)!important;}
.bc-sep{font-size:.34rem;color:var(--gold3);}

/* ═══ MAP ═══════════════════════════════════════════════════════════════════ */
#map-wrap{position:fixed;inset:0;top:52px;transition:transform .72s var(--ease);}
#map-wrap.shift{transform:translateX(-20%);}
#map-svg{width:100%;height:100%;display:block;}
.land{fill:var(--land);stroke:var(--border);stroke-width:.3px;cursor:pointer;transition:fill .15s,stroke .15s,filter .15s;}
[data-theme="dark"] .land.dimmed{fill:#141414;stroke:#202020;stroke-width:.2px;opacity:.45;}
[data-theme="light"] .land.dimmed{fill:#e2ddd0;stroke:#ccc6b4;stroke-width:.2px;opacity:.5;}
.land.cont-EU:hover{fill:#3a2e10;stroke:var(--eu);stroke-width:.85px;filter:drop-shadow(0 0 4px var(--eu-g));}
.land.cont-NA:hover{fill:#0f3040;stroke:var(--na);stroke-width:.85px;filter:drop-shadow(0 0 4px var(--na-g));}
.land.cont-SA:hover{fill:#0e3420;stroke:var(--sa);stroke-width:.85px;filter:drop-shadow(0 0 4px var(--sa-g));}
.land.cont-AF:hover{fill:#321a08;stroke:var(--af);stroke-width:.85px;filter:drop-shadow(0 0 4px var(--af-g));}
.land.cont-AS:hover{fill:#321414;stroke:var(--as);stroke-width:.85px;filter:drop-shadow(0 0 4px var(--as-g));}
.land.cont-OC:hover{fill:#152440;stroke:var(--oc);stroke-width:.85px;filter:drop-shadow(0 0 4px var(--oc-g));}
.land:not([class*="cont-"]):hover{filter:brightness(1.5);}
[data-theme="light"] .land.cont-EU:hover{fill:#d8cc8c;stroke:var(--eu);}
[data-theme="light"] .land.cont-NA:hover{fill:#88bcd4;stroke:var(--na);}
[data-theme="light"] .land.cont-SA:hover{fill:#88d4ac;stroke:var(--sa);}
[data-theme="light"] .land.cont-AF:hover{fill:#d4a870;stroke:var(--af);}
[data-theme="light"] .land.cont-AS:hover{fill:#d49090;stroke:var(--as);}
[data-theme="light"] .land.cont-OC:hover{fill:#90a4d8;stroke:var(--oc);}
.land.selected{stroke:var(--gold)!important;stroke-width:1.2px!important;filter:drop-shadow(0 0 8px rgba(200,168,80,.4))!important;}
.land.visited-mark{opacity:.9;}
.pdot{pointer-events:none;}
.pd-c{animation:pdC 3s ease-in-out infinite;}
.pd-r{fill:none;stroke:var(--gold);stroke-width:.6;animation:pdR 3s ease-in-out infinite;}
@keyframes pdC{0%,100%{r:2.6;opacity:.72;}50%{r:4;opacity:.18;}}
@keyframes pdR{0%,100%{r:6.5;opacity:.38;}50%{r:10;opacity:0;}}

/* ═══ LEGEND ════════════════════════════════════════════════════════════════ */
#legend{position:fixed;bottom:38px;left:38px;z-index:100;opacity:0;animation:fIn .8s ease 2s forwards;}
.leg{display:flex;align-items:center;gap:7px;margin-bottom:7px;cursor:pointer;transition:opacity .2s;}
.leg:hover{opacity:.6;}
.leg:focus-visible{outline:1px solid var(--gold);}
.ldot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.ltx{font-size:.38rem;letter-spacing:.19em;color:var(--muted);text-transform:uppercase;}

/* ═══ DASHBOARD ══════════════════════════════════════════════════════════════ */
#dashboard{
  position:fixed;bottom:42px;left:50%;transform:translateX(-50%);
  z-index:90;display:flex;gap:11px;
  opacity:0;animation:fIn .9s ease 2.5s forwards;
  pointer-events:none;transition:opacity .35s;
}
#dashboard.gone{opacity:0!important;pointer-events:none!important;}
.dsh-c{
  background:var(--glass);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:1px solid var(--gb);padding:9px 15px;min-width:94px;text-align:center;border-radius:3px;
}
.dsh-lbl{font-size:.36rem;letter-spacing:.19em;color:var(--gold3);text-transform:uppercase;margin-bottom:4px;}
.dsh-val{font-size:.86rem;color:var(--fg);font-family:'Cormorant Garamond',serif;font-weight:400;}
.dsh-sub{font-size:.34rem;color:var(--muted);margin-top:2px;}

/* ═══ MILES HUB ══════════════════════════════════════════════════════════════ */
#miles-tab{
  position:fixed;left:0;top:50%;transform:translateY(-50%);
  width:28px;height:170px;
  background:var(--bg2);border-right:1px solid var(--gb);
  display:flex;align-items:center;justify-content:center;
  z-index:200;cursor:pointer;
  opacity:0;animation:fIn .8s ease 2s forwards;transition:border-color .25s;
}
#miles-tab:hover{border-right-color:rgba(200,168,80,.28);}
#miles-tab span{writing-mode:vertical-rl;transform:rotate(180deg);font-size:.4rem;letter-spacing:.3em;color:var(--muted);text-transform:uppercase;white-space:nowrap;transition:color .25s;}
#miles-tab:hover span{color:rgba(200,168,80,.55);}
#miles-hub{
  position:fixed;left:-320px;top:52px;bottom:0;width:310px;
  background:var(--glass);backdrop-filter:blur(40px);-webkit-backdrop-filter:blur(40px);
  border-right:1px solid var(--gb);z-index:190;
  transition:left .5s var(--ease);overflow-y:auto;
  scrollbar-width:thin;scrollbar-color:var(--scr) transparent;
}
#miles-hub.open{left:0;}
.mh-head{
  padding:16px 18px 12px;border-bottom:1px solid var(--gb);
  position:sticky;top:0;background:var(--glass);backdrop-filter:blur(20px);z-index:2;
  display:flex;align-items:flex-start;justify-content:space-between;
}
.mh-title{font-family:'Playfair Display',serif;font-size:.92rem;color:var(--gold);font-style:italic;}
.mh-sub{font-size:.37rem;letter-spacing:.17em;color:var(--muted);text-transform:uppercase;margin-top:2px;}
.mh-x{font-size:.8rem;color:var(--muted);transition:color .2s;padding:2px 4px;}
.mh-x:hover{color:var(--gold);}
.mh-body{padding:4px 0 36px;}
.acc{border-bottom:1px solid rgba(200,168,80,.08);}
.acc-h{display:flex;align-items:center;justify-content:space-between;padding:12px 18px;cursor:pointer;transition:background .12s;}
.acc-h:hover{background:var(--gold4);}
.acc-hl{display:flex;align-items:center;gap:9px;}
.acc-ico{font-size:.9rem;}
.acc-ti{font-size:.57rem;color:var(--fg);letter-spacing:.05em;font-weight:400;}
.acc-su{font-size:.37rem;color:var(--muted);letter-spacing:.1em;margin-top:1px;}
.acc-ar{font-size:.46rem;color:var(--gold3);transition:transform .28s;}
.acc.is-open .acc-ar{transform:rotate(180deg);}
.acc-bd{display:none;padding:2px 18px 14px;}
.acc.is-open .acc-bd{display:block;}
.acc-p{font-size:.61rem;color:var(--dim);line-height:1.85;margin-bottom:7px;}
.acc-ul{list-style:none;}
.acc-ul li{font-size:.6rem;color:var(--dim);padding:5px 0;border-bottom:1px solid rgba(200,168,80,.06);display:flex;gap:7px;line-height:1.55;}
.acc-ul li:last-child{border:none;}
.acc-ul li::before{content:"›";color:var(--gold3);flex-shrink:0;}
.acc-tag{display:inline-block;font-size:.37rem;letter-spacing:.1em;padding:3px 7px;border:1px solid rgba(200,168,80,.16);color:var(--gold3);text-transform:uppercase;margin:3px 2px 0 0;border-radius:2px;}
.gl-row{display:flex;gap:9px;padding:6px 0;border-bottom:1px solid rgba(200,168,80,.06);font-size:.59rem;}
.gl-row:last-child{border:none;}
.gl-term{color:var(--gold2);font-weight:500;min-width:80px;flex-shrink:0;}
.gl-def{color:var(--dim);line-height:1.55;}

/* ═══ MAIN PANEL ════════════════════════════════════════════════════════════ */
#panel{
  position:fixed;right:0;top:52px;bottom:0;
  width:40vw;min-width:420px;max-width:640px;
  background:var(--glass);backdrop-filter:blur(44px);-webkit-backdrop-filter:blur(44px);
  border-left:1px solid var(--gb);z-index:350;
  transform:translateX(100%);transition:transform .7s var(--ease);
  display:flex;flex-direction:column;
  box-shadow:-8px 0 40px var(--shadow);
}
#panel.open{transform:translateX(0);}
#p-bar{display:flex;align-items:center;gap:9px;padding:9px 14px;border-bottom:1px solid var(--gb);flex-shrink:0;background:var(--glass);backdrop-filter:blur(16px);}
#p-x{width:24px;height:24px;border:1px solid var(--gb);display:flex;align-items:center;justify-content:center;font-size:.78rem;color:var(--muted);transition:all .2s;border-radius:3px;flex-shrink:0;}
#p-x:hover{border-color:var(--gold);color:var(--gold);background:var(--gold4);}
#p-bc-inner{font-size:.39rem;letter-spacing:.15em;color:var(--muted);text-transform:uppercase;display:flex;gap:5px;align-items:center;}
#p-bc-inner .sep{color:var(--gold3);}
#visited-btn{
  margin-left:auto;display:flex;align-items:center;gap:5px;
  border:1px solid var(--gb);color:var(--muted);
  font-size:.38rem;letter-spacing:.14em;text-transform:uppercase;
  padding:4px 9px;transition:all .22s;border-radius:3px;white-space:nowrap;
}
#visited-btn:hover,#visited-btn.on{border-color:var(--sa);color:var(--sa);background:rgba(50,168,112,.06);}
#p-tabs{display:flex;border-bottom:1px solid var(--gb);flex-shrink:0;background:var(--bg2);}
.pt{
  flex:1;padding:9px 3px;font-size:.37rem;letter-spacing:.11em;
  color:var(--muted);text-transform:uppercase;text-align:center;
  cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;
}
.pt:hover{color:var(--dim);}
.pt.on{color:var(--gold);border-bottom-color:var(--gold);}
#p-scroll{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--scr) transparent;}
.pane{display:none;}.pane.on{display:block;}

/* ── TAB 0: CHECK-IN ─────────────────────────────────────────────────────── */
.polaroid-gallery{
  display:flex;gap:0;overflow-x:auto;padding:14px 16px 10px;
  scrollbar-width:none;background:var(--bg2);border-bottom:1px solid var(--gb);
}
.polaroid-gallery::-webkit-scrollbar{display:none;}
.polaroid{
  flex-shrink:0;width:140px;
  background:white;padding:6px 6px 22px;
  box-shadow:0 3px 14px rgba(0,0,0,.35),0 1px 4px rgba(0,0,0,.2);
  margin-right:10px;transform:rotate(var(--rot));
  transition:transform .25s,box-shadow .25s;cursor:default;position:relative;
}
[data-theme="light"] .polaroid{box-shadow:0 3px 14px rgba(0,0,0,.18),0 1px 4px rgba(0,0,0,.1);}
.polaroid:hover{transform:rotate(0deg) scale(1.04);box-shadow:0 8px 30px rgba(0,0,0,.5);z-index:2;}
.polaroid img{width:100%;height:90px;object-fit:cover;display:block;background:#222;}
.polaroid-cap{font-family:'Montserrat',sans-serif;font-size:.38rem;color:#444;text-align:center;margin-top:5px;letter-spacing:.06em;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;}
.ctry-head{padding:12px 18px 8px;border-bottom:1px solid var(--gb);}
.ctry-flag{font-size:2rem;margin-bottom:5px;line-height:1;}
.ctry-name{font-family:'Playfair Display',serif;font-size:1.7rem;font-weight:500;color:var(--fg);line-height:1.1;margin-bottom:2px;}
.ctry-region{font-size:.39rem;letter-spacing:.3em;color:var(--gold3);text-transform:uppercase;}
.tab-body{padding:14px 18px;}
.sec-lbl{font-size:.38rem;letter-spacing:.21em;color:var(--gold3);text-transform:uppercase;margin-bottom:9px;font-weight:500;}
.ess-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:14px;}
.ess-c{background:var(--card);border:1px solid var(--gb);padding:10px 12px;border-radius:3px;}
.ess-ico{font-size:.95rem;margin-bottom:4px;}
.ess-lbl{font-size:.35rem;letter-spacing:.17em;color:var(--gold3);text-transform:uppercase;margin-bottom:3px;}
.ess-val{font-size:.68rem;color:var(--fg);font-weight:400;line-height:1.3;}
.ess-sub{font-size:.5rem;color:var(--dim);margin-top:2px;}
.rate-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(50,168,112,.08);border:1px solid rgba(50,168,112,.18);padding:3px 8px;border-radius:2px;font-size:.44rem;color:var(--sa);margin-top:4px;font-weight:500;}
.months-row{display:grid;grid-template-columns:repeat(12,1fr);gap:2px;margin-bottom:5px;}
.mo-cell{text-align:center;}
.mo-bar{border-radius:2px;margin-bottom:2px;transition:opacity .2s;}
.mo-bar:hover{opacity:.75;}
.mo-l{font-size:.33rem;color:var(--muted);}
.mo-leg{display:flex;gap:12px;margin-top:5px;margin-bottom:12px;}
.mol-i{display:flex;align-items:center;gap:4px;font-size:.35rem;color:var(--muted);}
.mol-d{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.best-q{font-size:.63rem;color:var(--dim);line-height:1.85;font-style:italic;border-left:2px solid var(--gold3);padding-left:10px;margin-top:10px;}
.terr-box{margin-top:12px;padding:10px 12px;background:var(--gold4);border:1px solid rgba(200,168,80,.12);border-radius:3px;font-size:.6rem;color:var(--dim);line-height:1.7;}

/* ── TAB 1: BUROCRACIA ───────────────────────────────────────────────────── */
.conflict-card{padding:11px 13px;border-radius:3px;margin-bottom:12px;border:1px solid;}
.conflict-card.green{background:rgba(50,168,112,.06);border-color:rgba(50,168,112,.2);}
